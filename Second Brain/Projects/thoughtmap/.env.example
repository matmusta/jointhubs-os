# ThoughtMap — Environment Configuration
# Copy this file to .env and adjust paths to your data.
#
# On Windows, use forward slashes: C:/Users/you/Documents/...
# On macOS/Linux, use normal paths: /home/you/Documents/...

# (optionally) Path to your current Obsidian vault root directory
OBSIDIAN_VAULT=C:/Users/mateu/Documents/Obsidian Vault

# (optionally) Path to the directory containing Wispr Flow's flow.sqlite
WISPR_DB_DIR=C:/Users/mateu/AppData/Roaming/Wispr Flow

# Include notes starting from this year (default: 2025)
# THOUGHTMAP_MIN_YEAR=2025

# ─── Embedding provider ───
# Options: "ollama" (default, local), "openai", "google"
# EMBEDDING_PROVIDER=ollama

# Ollama (default)
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b

# OpenAI (if EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google (if EMBEDDING_PROVIDER=google)
# GOOGLE_API_KEY=...
# GOOGLE_EMBEDDING_MODEL=text-embedding-004

# Embedding dimensions (default: 768)
# EMBEDDING_DIMENSIONS=768

# Named Entity Recognition
# THOUGHTMAP_NER_ENABLED=true
# THOUGHTMAP_NER_SPACY_MODEL=xx_ent_wiki_sm
# THOUGHTMAP_NER_MIN_MENTIONS=2
# THOUGHTMAP_NER_MAX_ENTITIES=250
# THOUGHTMAP_NER_MAX_OLLAMA_SUMMARIES=50
