# Jointhubs .gitignore

# ======================
# CREDENTIALS — NEVER COMMIT
# ======================
client.json
credentials.json
token.json
*.pem
*.key
*.p12

# Environment files
.env
.env.local
.env.*.local
.env.production

# VS Code MCP config (contains secrets)
.vscode/mcp.json
.vscode/settings.json

# ======================
# LOCAL TOOLS & RUNTIME
# ======================
.claude/
.graphify_python
.playwright-mcp/
tmp/
.obsidian/

# ======================
# PERSONAL/TEMPORARY FILES
# ======================
Second Brain/Projects/tmp/
tasks/
*.personal.md

# Local AI customizations (keep private experiments and personal workflows out of upstream)
.github/agents/local/**
!.github/agents/local/README.md
.github/skills/local/**
!.github/skills/local/README.md
.github/prompts/local/**
!.github/prompts/local/README.md
.github/instructions/local/**
!.github/instructions/local/README.md

# ======================
# VAULT CONTENT (keep structure, ignore personal notes)
# ======================

# Operations — keep shared docs, ignore periodic and meeting notes
Second Brain/Operations/Periodic Notes/*.md
Second Brain/Operations/Periodic Notes/**/*.md
!Second Brain/Operations/Periodic Notes/README.md
!Second Brain/Operations/Periodic Notes/**/README.md
Second Brain/Operations/Meetings/*.md
Second Brain/Operations/Meetings/**/*.md
!Second Brain/Operations/Meetings/README.md
!Second Brain/Operations/Meetings/**/README.md

# Personal operations (reviews, summaries, linkedin drafts)
Second Brain/Operations/weekly-reviews/
Second Brain/Operations/weekly-status/
Second Brain/Operations/Reviews/
Second Brain/Operations/linkedin/
**/linkedin/

# ThoughtMap output (generated from YOUR notes — sensitive)
Second Brain/Operations/thoughtmap-out/
!Second Brain/Operations/thoughtmap-out/README.md

# Obsidian sub-vault config (personal)
Second Brain/.obsidian/

# Personal — ignore all notes recursively (contains sensitive data)
Second Brain/Personal/**
!Second Brain/Personal/README.md
!Second Brain/Personal/**/README.md

# Projects — ignore all except whitelisted
Second Brain/Projects/*
!Second Brain/Projects/README.md
!Second Brain/Projects/thoughtmap/

# Keep README files for structure documentation
!**/README.md

# ======================
# DEPENDENCIES
# ======================

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
.venv/
venv/
ENV/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ======================
# EDITORS & OS
# ======================

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/mcp.json.example

# Obsidian — keep root config for consistent experience
# .obsidian/ is NOT ignored — we want to share plugin configs
.obsidian/workspace.json

# JetBrains
.idea/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ======================
# THOUGHTMAP (vector DB & runtime cache — generated locally)
# ======================
Second Brain/Projects/thoughtmap/data/
Second Brain/Projects/thoughtmap/graphify-out/

# ======================
# BUILD & LOGS
# ======================
*.log
logs/
Second Brain/Operations/automation-logs/
dist/
build/
*.egg-info/
.Rproj.user
